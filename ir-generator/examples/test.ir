}

define void @testBreakAndContinue(int %x, int %y) {

%r110 = alloca int
store int %x, int* %r110
%r111 = alloca int
store int %y, int* %r111

L20:
%r112 = load int, int* %r110
%r113 = seti int 9
%r114 = int %r112 < int %r113
br %r114, label L21, label L22

L21:
%r115 = seti int 2
store int %r115, int* %r110
%r116 = load int, int* %r110
%r117 = seti int 4
%r118 = int %r116 < int %r117
br %r118, label L23, label L24

L23:
br label L22
br label L25

L24:
br label L20
br label L25

L25:
%r119 = seti int 3
store int %r119, int* %r110
br label L20

L22:
ret void

}

