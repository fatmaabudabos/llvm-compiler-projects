define int @testCall(int %x, int * %y) {

%r135 = alloca int
store int %x, int* %r135
%r136 = alloca int *
store int * %y, int ** %r136
%r137 = load int, int* %r135
%r138 = load int *, int ** %r136
%r139 = load int, int* %r138
%r140 = int %r137 + int %r139
ret int %r140

}

define int @main() {

%r141 = alloca int
%r142 = seti int 1
store int %r142, int* %r141
%r143 = alloca int
%r144 = seti int 1
%r145 = call int @testCall(int %r144, int * %r141)
store int %r145, int* %r143
%r146 = seti int 0
