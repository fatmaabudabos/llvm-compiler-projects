define void @testForLoop() {

%r99 = alloca int
%r100 = seti int 0
store int %r100, int* %r99
br label L16

L16:
%r101 = load int, int* %r99
%r102 = seti int 10
%r103 = int %r101 < int %r102
br %r103, label L17, label L19

L17:
%r104 = load int, int* %r99
%r105 = seti int 2
%r106 = int %r104 + int %r105
store int %r106, int* %r99
br label L18

L18:
